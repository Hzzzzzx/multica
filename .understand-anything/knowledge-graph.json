  "tour": [
    {
      "order": 1,
      "title": "项目概览",
      "description": "Multica 是开源托管 AI Agent 平台。Go 后端（Chi + pgx + sqlc）+ Next.js 前端 + Electron 桌面端。核心价值：把 Claude Code、Codex 等 CLI Agent 变成看板上的团队成员。",
      "nodeIds": [
        "document:README.md",
        "document:CLAUDE.md"
      ]
    },
    {
      "order": 2,
      "title": "程序入口与服务启动",
      "description": "server/cmd/server/main.go 启动 HTTP API 服务。router.go 注册所有路由，挂载中间件链（认证→CORS→CSP→限流→日志），然后注册公开路由（auth/config）和受保护路由组（api/*）。",
      "nodeIds": [
        "file:server/cmd/server/main.go",
        "file:server/cmd/server/router.go"
      ]
    },
    {
      "order": 3,
      "title": "Agent 执行运行时 — 核心抽象",
      "description": "server/pkg/agent/agent.go 定义了 Backend 接口（只有 Execute 方法）。每种 Agent CLI（claude.go, codex.go, codebuddy.go 等）实现这个接口。New() 工厂函数根据 agentType 字符串返回对应实现。这是整个项目最核心的设计——统一调度 13 种 Agent CLI。",
      "nodeIds": [
        "file:server/pkg/agent/agent.go",
        "file:server/pkg/agent/claude.go",
        "file:server/pkg/agent/codebuddy.go"
      ]
    },
    {
      "order": 4,
      "title": "Daemon — 本地守护进程",
      "description": "daemon.go 是 Agent 的本地执行者。config.go 探测 PATH 上的 Agent CLI（exec.LookPath + login shell fallback），daemon.go 管理任务队列、spawn 子进程、心跳上报、workdir 分配。execenv/ 管理每种 Agent 的运行环境配置。",
      "nodeIds": [
        "file:server/internal/daemon/daemon.go",
        "file:server/internal/daemon/config.go"
      ]
    },
    {
      "order": 5,
      "title": "认证体系",
      "description": "邮箱验证码 OTP 登录（无需密码）。auth.go 的 SendCode 发验证码，VerifyCode 验证并签发 JWT。cookie.go 设置 HttpOnly cookie（multica_auth + multica_csrf）。支持 MULTICA_DEV_VERIFICATION_CODE 做开发环境固定验证码。",
      "nodeIds": [
        "file:server/internal/handler/auth.go",
        "file:server/internal/auth/cookie.go",
        "file:server/internal/auth/jwt.go"
      ]
    },
    {
      "order": 6,
      "title": "中间件链",
      "description": "每个请求经过：RequestID → ClientMetadata → RequestLogger → Recoverer → CSP → CORS → Auth。Auth 中间件解析 JWT、设置 X-User-ID 头、验证 CSRF。",
      "nodeIds": [
        "file:server/internal/middleware/auth.go",
        "file:server/internal/middleware/csp.go",
        "file:server/internal/middleware/ratelimit.go"
      ]
    },
    {
      "order": 7,
      "title": "数据访问 — sqlc 模式",
      "description": "Multica 不用 ORM。开发者在 server/pkg/db/queries/*.sql 写 SQL，sqlc 编译时生成类型安全的 Go 代码（server/pkg/db/generated/*.sql.go）。pgx/v5 提供连接池和底层 PostgreSQL 驱动。",
      "nodeIds": [
        "file:server/sqlc.yaml",
        "file:server/pkg/db/queries/issue.sql"
      ]
    },
    {
      "order": 8,
      "title": "飞书集成",
      "description": "server/internal/integrations/lark/ 是完整的飞书 Bot 集成。WebSocket 长连接接收消息，dispatcher 分发，outbound 发送。支持在飞书群里创建 issue、分配 Agent、接收进度推送。",
      "nodeIds": [
        "file:server/internal/integrations/lark/ws_connector.go",
        "file:server/internal/integrations/lark/dispatcher.go"
      ]
    },
    {
      "order": 9,
      "title": "定时任务调度",
      "description": "scheduler/ 基于 pgcron（PostgreSQL 定时任务扩展）实现。manager.go 轮询任务表，jobs_task_usage.go 做每小时用量 rollup。autopilot 可以配置 cron 触发器，自动创建 issue 并分配给 Agent。",
      "nodeIds": [
        "file:server/internal/scheduler/manager.go",
        "file:server/internal/scheduler/jobs_task_usage.go"
      ]
    },
    {
      "order": 10,
      "title": "部署架构",
      "description": "开发用 make dev（本地 Docker PostgreSQL + Go + Next.js）。生产用 Helm chart 部署到 K8s。CI/CD 用 GitHub Actions。也支持 self-host（docker-compose.selfhost.yml）。",
      "nodeIds": [
        "config:docker-compose.yml",
        "config:Dockerfile",
        "service:deploy/helm/multica/templates/backend.yaml"
      ]
    }
  ],
